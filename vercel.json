{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/stocks", "destination": "/api/stocks" },
    { "source": "/api/history/:path*", "destination": "/api/history" }
  ]
}
